APP_NAME="my-mini-rag-app"
APP_VERSION="x.x.x"
APP_DESCRIPTION="A mini RAG app"
APP_AUTHOR="my_name"

FILE_ALLOWED_TYPES=["text/plain","application/pdf"]
FILE_MAX_SIZE=50 # 50MB
FILE_DEFAULT_CHUNK_SIZE=512000 # 512KB



MONGODB_URL="mongodb://your_username:your_password@IP_ADDRESS:PORT_NUMBER"
MONGODB_DATABASE="your_database_name"


#====================LLM Settings====================
GENERATION_BACKEND="GEMINI"
EMBEDDING_BACKEND="GEMINI"

GENERATION_MODEL_ID="YOUR_GENERATION_MODEL_ID"
EMBEDDING_MODEL_ID="YOUR_EMBEDDING_MODEL_ID"
EMBEDDING_SIZE=768

DEFAULT_INPUT_MAX_CHARACTERS=1024
DEFAULT_GENERATION_MAX_TOKENS=1000
DEFAULT_GENERATION_TEMPERATURE=0.1

GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
COHERE_API_KEY="YOUR_COHERE_API_KEY"
