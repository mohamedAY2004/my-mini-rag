APP_NAME="my-mini-rag-app"
APP_VERSION="x.x.x"
APP_DESCRIPTION="A mini RAG app"
APP_AUTHOR="my_name"

FILE_ALLOWED_TYPES=["text/plain","application/pdf"]
FILE_MAX_SIZE=50 # 50MB
FILE_DEFAULT_CHUNK_SIZE=512000 # 512KB



#====================PostgreSQL Settings====================
POSTGRES_USERNAME="your_username"
POSTGRES_PASSWORD="your_password"
POSTGRES_DATABASE="your_database_name"
POSTGRES_HOST="host_address"
POSTGRES_PORT=host_port


#====================LLM Settings====================
GENERATION_BACKEND="GEMINI"
EMBEDDING_BACKEND="GEMINI"

GENERATION_MODEL_ID="YOUR_GENERATION_MODEL_ID"
EMBEDDING_MODEL_ID="YOUR_EMBEDDING_MODEL_ID"
EMBEDDING_SIZE=768

DEFAULT_INPUT_MAX_CHARACTERS=1024
DEFAULT_GENERATION_MAX_TOKENS=1000
DEFAULT_GENERATION_TEMPERATURE=0.1

GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_API_URL="YOUR_OPENAI_API_URL"
COHERE_API_KEY="YOUR_COHERE_API_KEY"

#====================VectorDB Settings====================
VECTORDB_BACKEND="QDRANT"
VECTORDB_PATH="qdrant_db"
VECTORDB_DISTANCE_METHOD="COSINE"

#====================Template Settings====================
DEFAULT_LANGUAGE="en"